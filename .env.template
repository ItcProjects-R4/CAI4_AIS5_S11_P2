# Customer Data ETL Environment Configuration
# نموذج متغيرات البيئة لمشروع ETL بيانات العملاء
#
# Instructions / التعليمات:
# 1. Copy this file to .env: cp .env.template .env
#    انسخ هذا الملف إلى .env: cp .env.template .env
# 2. Uncomment and fill in your credentials below
#    قم بإلغاء التعليق وملء بيانات الاعتماد أدناه
# 3. NEVER commit .env to git
#    لا تقم بالتزام .env في git
# 4. Keep this template generic without real secrets
#    احتفظ بهذا النموذج عام بدون أسرار حقيقية

# ==============================================================================
# Database Configuration / إعدادات قاعدة البيانات
# ==============================================================================

# SQL Server / SQL Server connection parameters
# مثال: DB_SERVER=localhost,1433
# أو: DB_SERVER=my-sql-server.database.windows.net
DB_SERVER=localhost,1433

# Database name / اسم قاعدة البيانات
DB_NAME=customer_data_etl

# Database user / مستخدم قاعدة البيانات
# غير حساس للحالة عادة
DB_USER=sa

# Database password / كلمة مرور قاعدة البيانات
# التحذير: مهم جدا! لا تضع كلمة المرور الحقيقية هنا في المستودع
# WARNING: CRITICAL! Never commit the real password to the repository!
DB_PASSWORD=YourSecurePasswordHere123!

# ==============================================================================
# Application Environment / بيئة التطبيق
# ==============================================================================

# Environment mode: development, staging, production
# نمط البيئة: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# مستوى التسجيل: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# ==============================================================================
# Feature Flags / علامات الميزات
# ==============================================================================

# Enable mock data generation for testing
# تفعيل توليد بيانات وهمية للاختبار
ENABLE_MOCK_DATA=True

# Skip ODBC driver validation (useful when drivers not installed)
# تخطي التحقق من بيانات اعتماد ODBC (مفيد عند عدم تثبيت برامج التشغيل)
# SKIP_ODBC_CHECK=False
