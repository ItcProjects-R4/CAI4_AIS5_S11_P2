# PostgreSQL Database Configuration
# Copy this file to .env and update values as needed
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432
DB_HOST=localhost
DB_NAME=shoporder
# Python Driver
DB_DRIVER=psycopg2

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ETL Configuration
CHUNK_SIZE=1000
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_SECONDS=5
